rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) 
        && data.keys().size() <= 7
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() > 0 && data.email.size() <= 256
        && data.createdAt is timestamp;
    }

    function isValidAnimalProfile(data) {
      return data.keys().hasAll(['userId', 'name', 'type', 'environment'])
        && data.keys().size() <= 9
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.type is string && data.environment is string;
    }

    function isValidAnalysisResult(data) {
      return data.keys().hasAll(['userId', 'timestamp', 'status'])
        && data.keys().size() <= 10
        && data.userId == request.auth.uid
        && data.timestamp is timestamp
        && data.status is string;
    }

    // Collection Matches
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isEmailVerified() && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'accessibilitySettings', 'updatedAt']);
    }

    match /profiles/{profileId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isEmailVerified() && isValidAnimalProfile(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidAnimalProfile(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'type', 'environment', 'age', 'breed', 'updatedAt']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /history/{analysisId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isEmailVerified() && isValidAnalysisResult(incoming());
    }
  }
}
